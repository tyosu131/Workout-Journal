# Frontend environment variables
# Copy to frontend/.env or configure these in the hosting environment.
# NEXT_PUBLIC_* variables are bundled into the browser, so do not put private secrets here.

# Backend API base URL.
# Local example:
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase public project URL, if frontend Supabase APIs are used.
NEXT_PUBLIC_SUPABASE_URL=https://example-supabase-project-url.invalid

# Supabase anon/public key only. Do not use a service-role key in the frontend.
NEXT_PUBLIC_SUPABASE_KEY=replace-with-supabase-anon-public-key
