# Backend environment variables
# Copy to backend/.env or backend/.env.local for local development.
# Do not commit real secrets.

# Express server port. Defaults to 3001 when unset.
PORT=3001

# Allowed browser origin for credentialed CORS requests.
# Local example:
CORS_ORIGIN=http://localhost:3000
# Alternative name also supported by backend/server.js:
# FRONTEND_ORIGIN=http://localhost:3000

# Supabase project URL.
SUPABASE_URL=https://example-supabase-project-url.invalid

# Supabase key used by the backend. Treat as secret if this is a service-role key.
SUPABASE_KEY=replace-with-supabase-backend-key

# JWT signing secret. Must be secret in every environment.
JWT_SECRET=replace-with-jwt-secret

# Optional token lifetimes. Defaults are defined in backend/utils/authUtils.js.
ACCESS_TOKEN_EXPIRES=1h
REFRESH_TOKEN_EXPIRES=7d
